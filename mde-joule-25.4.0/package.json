{
	"name": "mde-joule",
	"displayName": "mde-joule",
	"description": "MDK Editor Joule",
	"version": "25.4.0",
	"publisher": "SAPSE",
	"engines": {
		"vscode": "^1.76.0"
	},
	"repository": {
		"type": "git",
		"url": "",
		"directory": "mde-joule"
	},
	"categories": [
		"Other"
	],
	"main": "./out/extension.js",
	"activationEvents": [
		"onStartupFinished"
	],
	"BASContributes": {
		"joule-development": {}
	},
	"scripts": {
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile",
		"test": "node ./out/test/runTest.js",
		"package": "vsce package",
		"vscode:prepublish": "npm run esbuild-base -- --sourcemap",
		"esbuild-base": "esbuild ./src/*.ts ./src/**/*.ts --outdir=out --format=cjs --platform=node",
		"esbuild": "npm run esbuild-base -- --sourcemap",
		"esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
		"test-compile": "tsc -p ./",
		"updatecds": "ts-node ./src/tools/updateCds.ts"
	},
	"dependencies": {
		"@sap/gai-core": "^0.19.1",
		"@sap/swa-for-sapbas-vsx": "^2.0.7",
		"@vscode-logging/logger": "1.2.3",
		"glob": "^7.1.5",
		"lodash": "4.17.21",
		"xml2js": "^0.6.2"
	},
	"devDependencies": {
		"@sap-devx/app-studio-toolkit-types": "^1.8.0",
		"@types/fs-extra": "5.0.5",
		"@types/glob": "^7.1.1",
		"@types/lodash": "4.14.196",
		"@types/mocha": "^5.2.7",
		"@types/node": "20.4.5",
		"@types/vscode": "^1.76.0",
		"@vscode/vsce": "2.21.0",
		"esbuild": "^0.23.1",
		"mocha": "^6.2.2",
		"ts-loader": "^7.0.3",
		"ts-node": "10.9.1",
		"typescript": "4.9.5",
		"vscode-test": "^1.2.2"
	},
	"extensionDependencies": [
		"SAPOSS.app-studio-toolkit"
	]
}
